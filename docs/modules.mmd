flowchart TD

    USER["👤 Nhân viên IT\n(Telegram / Dashboard)"]

    subgraph CLIENT["MODULE 1 — Giao diện người dùng"]
        direction LR
        BOT["🤖 Telegram Bot\n• Nhận tin nhắn + ảnh\n• Cache ảnh 5 phút\n• Gửi trả lời HTML\n─────────────────\n⚡ async, không giới hạn kết nối"]
        UI["📊 Dashboard Web :8000/ui\n• Xem trạng thái hệ thống\n• Stream log real-time (WS)\n• Test OCR / Visual Q&A\n─────────────────\n⚡ React SPA, nhẹ"]
    end

    subgraph GW["MODULE 2 — API Gateway  :8000  (FastAPI, 1 process)"]
        direction LR
        GW_ROUTE["🔌 Router\nPOST /ask\nGET  /health\nWS   /logs"]
        GW_MEM["💾 Session Memory\nTTL 2h, tối đa 2.000 sessions\nLưu RAM in-process\n─────────────────\n⚠️ Không dùng Redis\nRestart là mất session"]
    end

    subgraph AGENT["MODULE 3 — Agent Runtime  :8001  (LangGraph Self-RAG, 1 process)"]
        direction LR
        AG_OCR["🖼️ Nhận diện ảnh\nOCR bằng Vision LLM\n(qwen2.5vl:7b)\n─────────────────\n⏱ ~5-10 giây/ảnh"]
        AG_RAG["🧠 Self-RAG Engine\n1. Quyết định có tìm FAQ không\n2. Tìm kiếm Qdrant\n3. LLM chấm điểm (grade)\n4. Nếu kém: rewrite và tìm lại\n5. Sinh câu trả lời\n─────────────────\n⏱ ~3-8 giây (1-3 vòng lặp)\n⚠️ Xử lý TUẦN TỰ (queue)"]
    end

    subgraph VECTOR["MODULE 4 — Qdrant Vector DB  :6333"]
        QD["🗄️ Collection: ehc_faq\nCosine, 1024-dim\nDữ liệu FAQ từ Redmine\n─────────────────\n✅ Nhanh ~50ms/query\nKhông phải bottleneck"]
    end

    subgraph GPU["MODULE 5 — GPU Server  (n3.ckey.vn:1534)"]
        direction LR
        TUNNEL["🔗 SSH Tunnel\nlocalhost:11435 to GPU:11434\n─────────────────\n⚠️ Single connection\nLatency ~50-150ms"]
        OLLAMA["⚙️ Ollama v0.19.0\nqwen2.5:14b  — LLM chính\nqwen2.5vl:7b — Vision/OCR\nbge-m3       — Embedding\n─────────────────\n🔴 BOTTLENECK CHÍNH\nRTX 3090 24GB DÙNG CHUNG\n1-2 request LLM song song\n~5-15 giây/câu hỏi"]
    end

    subgraph INGEST["MODULE 6 — Ingestion Pipeline  (Offline / Cron)"]
        ING["📥 Redmine to Qdrant\nCrawl ticket, chunk 500 ký tự\nEmbed bằng bge-m3, upsert\n─────────────────\nChạy thủ công hoặc lên lịch\nKhông ảnh hưởng realtime"]
    end

    REDMINE["📋 Redmine  co.ehc.vn:81\nNguồn dữ liệu FAQ"]

    CAPACITY["📊 ƯỚC TÍNH TẢI ĐỒNG THỜI\n──────────────────────────────────\n🟢  1-3 user  →  mượt, ~5-8s/câu\n🟡  4-6 user  →  queue, ~10-20s/câu\n🔴  7+ user   →  timeout, kém\n──────────────────────────────────\nTổng: ~10-15 câu hỏi/phút\nBottleneck: RTX 3090 dùng chung Ollama"]

    USER -->|Telegram| BOT
    USER -->|Browser| UI
    BOT -->|HTTP /ask timeout 240s| GW_ROUTE
    UI -->|REST/WebSocket| GW_ROUTE
    GW_ROUTE <--> GW_MEM
    GW_ROUTE -->|HTTP /invoke| AG_RAG
    AG_RAG -->|ảnh: OCR| AG_OCR
    AG_RAG -->|embed + search top-K| QD
    AG_OCR -->|Vision LLM| OLLAMA
    AG_RAG -->|LLM grade, generate, rewrite| OLLAMA
    OLLAMA <-.->|SSH Tunnel| TUNNEL
    ING -->|embed| OLLAMA
    ING -->|upsert vectors| QD
    ING -->|REST API| REDMINE
    OLLAMA -.-> CAPACITY

